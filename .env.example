# Required — fal.ai for video generation (Kling, etc.)
FAL_API_KEY=

# Required — ElevenLabs for voiceover & voice cloning
ELEVENLABS_API_KEY=

# Required — PostgreSQL connection string (Prisma)
DATABASE_URL=postgresql://user:pass@localhost:5432/blokblok?schema=public

# Required — Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required — NextAuth.js secret for session encryption
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Required in production — Protects API routes with Bearer token auth
# If not set in production, API returns 503. Fine for local dev.
SERVER_API_KEY=

# Optional — Comma-separated allowed origins for CORS
# In production: if not set, cross-origin requests are blocked
ALLOWED_ORIGINS=

# Optional — Cloudflare R2 for persistent file storage (recommended for voiceover audio)
# If not configured, voiceover audio falls back to base64 in database
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=

# Optional — Anthropic API for AI script generation
ANTHROPIC_API_KEY=

# Optional — Secret for cron endpoint auth
# Generate with: openssl rand -hex 32
CRON_SECRET=
